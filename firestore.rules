rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }
    function uidUnchanged() {
      return !('userId' in request.resource.data) || request.resource.data.userId == request.auth.uid;
    }
    function uidNotModified() {
      return !('userId' in request.resource.data) || request.resource.data.userId == resource.data.userId;
    }
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    function isValidClassData() {
      return hasRequiredFields(['id', 'name', 'feePerSession', 'students', 'sessions', 'userId', 'createdAt']) &&
             request.resource.data.id is string &&
             request.resource.data.name is string && request.resource.data.name.size() > 0 && request.resource.data.name.size() < 100 &&
             request.resource.data.feePerSession is number && request.resource.data.feePerSession >= 0 &&
             request.resource.data.students is list &&
             request.resource.data.sessions is list &&
             request.resource.data.userId is string &&
             request.resource.data.createdAt is number;
    }

    match /classes/{classId} {
      allow read: if isAuthenticated() && isDocOwner();
      allow create: if isAuthenticated() && isValidClassData() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && isDocOwner() && isValidClassData() && uidNotModified();
      allow delete: if isAuthenticated() && isDocOwner();
    }
  }
}
